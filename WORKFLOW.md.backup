---
# Symphony Multi-Project Configuration — KiloCode CLI Backend Example
#
# KiloCode CLI (kilo) runs AI coding agents in fully autonomous mode.
# Authenticate once with `kilo auth` or the interactive `/connect` command;
# no API key is required in this file when using Kilo Gateway models.
# See: https://kilo.ai/docs/cli
#
# Prerequisites:
#   npm install -g @kilocode/cli
#   kilo auth                  # one-time Kilo Gateway login
#   kilo --version             # verify installation

orchestrator:
  polling_interval_ms: 30000
  max_concurrent_agents: 5
  max_attempts: 3

tracker:
  backend: linear
  linear:
    api_key: $LINEAR_API_KEY
    active_states:
      - Todo
      - To Do
      - In Progress
      - Triage
    done_state: Done

# Project Routing Map — maps Linear project slugs to GitHub repos.
# Find your project slug in Linear: Settings → Projects → copy the slug from the URL.
projects:
  - name: "manidae-cloud"
    linear_project_slug: "36dc98f3d3c5"
    repo_url: "https://github.com/oidebrett/manidae-cloud.git"
    target_branch: "whitelabel"

workspace:
  root: /Users/mattercoder/symphony_workspaces

hooks:
  timeout_ms: 600000
  before_run: |
    set -e
    echo "Setting up workspace for {{issue_identifier}} in {{repo_name}}..."
    # Try to clone with retries and shallow clone for faster, more reliable cloning
    max_retries=3
    for i in $(seq 1 $max_retries); do
      echo "Clone attempt $i of $max_retries..."
      if git clone --depth 1 --branch {{target_branch}} --single-branch {{repo_url}} .; then
        echo "Clone successful on attempt $i"
        break
      else
        if [ $i -eq $max_retries ]; then
          echo "All clone attempts failed"
          exit 1
        fi
        echo "Clone attempt $i failed, retrying in 5 seconds..."
        sleep 5
        # Remove partial clone if it exists
        rm -rf .git
      fi
    done
    git checkout -b agent/{{issue_identifier}}
    # Copy local env files from ~/Projects/{{repo_name}}/ if present (these are gitignored).
    SRC="$HOME/Projects/{{repo_name}}"
    for f in .env .env.local backend/.env frontend/.env frontend/.env.local; do
      if [ -f "$SRC/$f" ]; then
        mkdir -p "$(dirname "$f")"
        cp "$SRC/$f" "$f"
        echo "copied $f from $SRC"
      fi
    done

  after_run: |
    set -e
    # Commit any uncommitted changes (safety net if agent forgot)
    if ! git diff-index --quiet HEAD --; then
      git add .
      git commit -m "{{issue_identifier}}: automated changes" || true
    fi
    # Ensure we're on the correct branch before pushing
    git checkout agent/{{issue_identifier}}
    # Push with retries
    max_retries=3
    for i in $(seq 1 $max_retries); do
      echo "Push attempt $i of $max_retries..."
      if git push origin agent/{{issue_identifier}}; then
        echo "Push successful on attempt $i"
        break
      else
        if [ $i -eq $max_retries ]; then
          echo "All push attempts failed"
          exit 1
        fi
        echo "Push attempt $i failed, retrying in 5 seconds..."
        sleep 5
      fi
    done
    # Create PR
    gh pr create \
      --repo {{repo_url}} \
      --base {{target_branch}} \
      --title '{{issue_identifier}}: {{issue_title}}' \
      --body '{{agent_summary}}' \
      --head agent/{{issue_identifier}} || echo "PR creation failed, but changes are pushed to branch agent/{{issue_identifier}}"

agent:
  backend: kilo

kilo:
  # Path or name of the Kilo CLI binary on PATH.
  command: kilo

  # Model in provider/model-id format. Run `kilo models` for the full list.
  # Models use the format provider/model-id. Run `kilo models` for the full list.
  # All Kilo Gateway models are prefixed with `kilo/`:
  #
  # Free (via Kilo Gateway):
  #   kilo/nvidia/nemotron-3-super-120b-a12b:free    NVIDIA Nemotron 3 Super 120B — FREE
  #   kilo/nvidia/nemotron-3-ultra-550b-a55b:free    NVIDIA Nemotron 3 Ultra 550B — FREE
  #   kilo/nvidia/nemotron-3-nano-omni-30b-a3b-reasoning:free
  #
  # Paid Kilo Gateway models:
  #   kilo/nvidia/nemotron-3-super-120b-a12b          (higher rate limits)
  #   kilo/anthropic/claude-sonnet-4-20250514
  #   kilo/anthropic/claude-opus-4-20250514
  #   kilo/google/gemini-2.5-pro
  #   kilo/openai/gpt-4o
  #
  # Custom / self-hosted providers can be registered in
  # ~/.config/kilo/opencode.json under `provider.<id>.models`.
  model: kilo/nvidia/nemotron-3-super-120b-a12b:free

  # Agent mode: code (default), architect, ask, debug, orchestrator.
  # Leave unset to use kilo's default (code mode).
  # agent_mode: code

  # Optional system prompt prepended to every issue prompt below.
  # system_prompt: |
  #   You are a senior engineer working on production code.
  #   Always run existing tests before finishing.

  turn_timeout_ms: 3600000
  stall_timeout_ms: 300000

server:
  port: 3000
---

You are an expert coding agent. Your goal is to resolve the provided issue: {{issue.identifier}} - {{issue.title}}.

Issue Description:
{{issue.description}}

Use the available tools to explore the codebase, edit files, and run tests.
Always use git commit after making changes.
When done, provide a concise summary of your work.
