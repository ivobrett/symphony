{
  "name": "symphony",
  "version": "1.0.0",
  "description": "Symphony is a long-running automation service that orchestrates AI coding agents to work on project issues. It continuously reads work from an issue tracker (Linear), creates isolated workspaces for each issue, and runs coding agent sessions to complete the work.",
  "main": "index.js",
  "scripts": {
    "start": "tsx src/index.ts",
    "build": "tsc",
    "dev": "tsx --watch src/index.ts",
    "typecheck": "tsc --noEmit"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/obelix74/symphony.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "type": "commonjs",
  "bugs": {
    "url": "https://github.com/obelix74/symphony/issues"
  },
  "homepage": "https://github.com/obelix74/symphony#readme",
  "dependencies": {
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^25.3.5",
    "chokidar": "^5.0.0",
    "fastify": "^5.8.1",
    "graphql-request": "^7.4.0",
    "js-yaml": "^4.1.1",
    "liquidjs": "^10.24.0",
    "pino": "^10.3.1",
    "pino-pretty": "^13.1.3",
    "tsx": "^4.21.0",
    "typescript": "^5.9.3"
  },
  "devDependencies": {
    "@types/pino": "^7.0.4"
  }
}
